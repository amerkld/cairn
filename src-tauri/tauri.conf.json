{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cairn",
  "version": "0.1.0",
  "identifier": "ai.al.cairn",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cairn",
        "width": 1200,
        "height": 780,
        "minWidth": 820,
        "minHeight": 560,
        "decorations": false,
        "resizable": true,
        "transparent": false,
        "backgroundColor": "#0e1013"
      },
      {
        "label": "quick-capture",
        "url": "quick-capture.html",
        "title": "Quick Capture",
        "width": 520,
        "height": 300,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "transparent": false,
        "backgroundColor": "#0e1013"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
